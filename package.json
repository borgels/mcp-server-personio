{
  "name": "mcp-server-personio",
  "version": "0.1.0",
  "description": "MCP server for the Personio HR API with employee and HR-admin profiles.",
  "type": "module",
  "main": "./dist/stdio.js",
  "exports": {
    ".": "./dist/stdio.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    ".env.example"
  ],
  "bin": {
    "mcp-server-personio": "./dist/stdio.js"
  },
  "scripts": {
    "build": "tsup src/transports/stdio.ts src/transports/http.ts --format esm --dts --clean --sourcemap",
    "dev": "tsx src/transports/stdio.ts",
    "dev:http": "tsx src/transports/http.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "npm run build",
    "prepack": "npm run typecheck && npm test && npm run build",
    "smoke:live": "tsx test/live-smoke.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borgels/mcp-server-personio.git"
  },
  "keywords": [
    "mcp",
    "personio",
    "hr",
    "absence",
    "time-tracking"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.11"
  },
  "bugs": {
    "url": "https://github.com/borgels/mcp-server-personio/issues"
  },
  "homepage": "https://github.com/borgels/mcp-server-personio#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "ip-address": ">=10.1.1",
    "hono": ">=4.12.25",
    "fast-uri": ">=3.1.2",
    "qs": ">=6.15.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}