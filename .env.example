# API credentials: Personio Settings -> Integrations -> API credentials.
# The same pair authenticates v2 (OAuth2) and the few remaining v1 endpoints.
PERSONIO_CLIENT_ID=
PERSONIO_CLIENT_SECRET=
PERSONIO_BASE_URL=https://api.personio.de
PERSONIO_TIMEOUT_MS=30000
# Tool profile: "employee" (self-service, hard-scoped to the requesting
# user's own data) or "hr" (company-wide HR workbench).
PERSONIO_PROFILE=employee
# Honor the gateway-forwarded X-MCP-User header as the acting identity.
# Required for the employee profile; only enable behind a gateway that
# sets this header itself from a verified token.
PERSONIO_TRUST_FORWARDED_USER=false
# HR write tools (update person, manage absence/attendance/projects,
# upload documents) additionally require exactly "true".
PERSONIO_ENABLE_WRITES=false
PERSONIO_AUDIT_LOG=
